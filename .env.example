DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fitness_backend?schema=public"
JWT_SECRET="replace-with-secure-secret"
JWT_EXPIRES_IN_SECONDS=604800
PORT=3000

# LLM Configuration for Chatbot
LLM_PROVIDER="groq"  # Options: groq, openai, gemini
LLM_API_KEY="your-api-key-here"

# ML Service Configuration
ML_SERVICE_URL="http://localhost:5000"

# Kaggle API Configuration (for dataset imports)
# See: https://github.com/Kaggle/kaggle-api#api-credentials
KAGGLE_USERNAME="your-kaggle-username"
KAGGLE_KEY="your-kaggle-api-key"

